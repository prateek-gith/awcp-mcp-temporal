{
  "id": null,
  "uid": "awcp-overview",
  "title": "AWCP Observability \u2014 Governance Edition",
  "description": "Agent Workforce Control Plane \u2014 HTTP, Workflow, Activity, MCP Tool telemetry, and Governance Evidence",
  "tags": [
    "awcp",
    "opentelemetry",
    "governance"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service_name",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(awcp_http_requests_total, service_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2
      },
      {
        "name": "tool_name",
        "label": "Tool",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(awcp_mcp_tool_calls_total, tool_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\ud83c\udf10 HTTP \u2014 FastAPI",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_http_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (errors/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_http_errors_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}} errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Duration P95 (s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(awcp_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "\u23f1 Temporal \u2014 Workflows",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Workflow Executions Total",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(awcp_workflow_executions_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Workflow Failures Total",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(awcp_workflow_failures_total)",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Workflow Duration P95 (s)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 120,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(awcp_workflow_duration_seconds_bucket[10m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Activity Executions (rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_activity_executions_total[1m])) by (activity)",
          "legendFormat": "{{activity}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(awcp_activity_failures_total[1m])) by (activity)",
          "legendFormat": "{{activity}} FAIL",
          "refId": "B"
        },
        {
          "expr": "sum(rate(awcp_activity_retries_total[1m])) by (activity)",
          "legendFormat": "{{activity}} RETRY",
          "refId": "C"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "\ud83d\udd27 MCP Tools",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Tool Call Rate by Tool Name (req/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_mcp_tool_calls_total[1m])) by (tool_name)",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Tool Failure Rate by Tool Name",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_mcp_tool_failures_total[1m])) by (tool_name)",
          "legendFormat": "{{tool_name}} fail",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "Tool Duration P95 by Tool Name (s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 19,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(awcp_mcp_tool_duration_seconds_bucket[5m])) by (le, tool_name))",
          "legendFormat": "p95 {{tool_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "\ud83c\udfdb Governance \u2014 Evidence & Degradation",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 51,
      "title": "Degradation Events by Mode",
      "description": "limited=tool failure | recommendation_only=synthesis fallback",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 10,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_degradation_events_total[1m])) by (degradation_mode)",
          "legendFormat": "{{degradation_mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 52,
      "title": "Policy Denials Total",
      "description": "Write-capable actions blocked by governance policy",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 10,
        "y": 28,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(awcp_policy_denials_total)",
          "legendFormat": "Denials",
          "refId": "A"
        }
      ]
    },
    {
      "id": 53,
      "title": "Replay Context Generated",
      "description": "Evidence packets generated per completed workflow branch",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 14,
        "y": 28,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(awcp_replay_context_generated_total)",
          "legendFormat": "Evidence Packets",
          "refId": "A"
        }
      ]
    },
    {
      "id": 54,
      "title": "Tool Timeouts by Tool Name",
      "description": "Calls that hit start-to-close timeout",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 28,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_tool_timeouts_total[5m])) by (tool_name)",
          "legendFormat": "{{tool_name}} timeout",
          "refId": "A"
        }
      ]
    },
    {
      "id": 55,
      "title": "Activity Retries per Workflow",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 10,
        "y": 32,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(awcp_workflow_retries_total[5m])) by (activity)",
          "legendFormat": "{{activity}} retry",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "\ud83d\udccb Logs (Loki) \u2014 Evidence-Oriented",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "AWCP Structured Logs (governance fields extracted)",
      "description": "Filter by workflow_id, agent_id, degradation_mode, checkpoint_id",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 10
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service_namespace=\"awcp\"} | json | line_format \"{{.event}} wf={{.workflow_id}} agent={{.agent_id}} tool={{.tool_name}} mode={{.degradation_mode}}\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "\ud83d\udd0d Traces (Tempo)",
      "gridPos": {
        "x": 0,
        "y": 47,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 41,
      "title": "Recent Traces \u2014 DynamicAskWorkflow (governance attributes)",
      "description": "Click any trace to see awcp.policy_mode, awcp.degradation_mode, awcp.agent_id, awcp.context_hash",
      "type": "traces",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "queryType": "search",
          "refId": "A",
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "value": [
                "awcp-control-api"
              ],
              "tag": "service.name",
              "type": "static"
            }
          ]
        }
      ]
    }
  ]
}